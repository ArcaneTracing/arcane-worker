# ============================================
# arcane Worker - Environment Configuration
# ============================================
# Copy to .env and fill in your values.
# See app/config.py for all supported settings.

# ============================================
# Logging
# ============================================
# LOG_LEVEL=DEBUG  # Enable for verbose debug logs (message receipt, processing steps)

# ============================================
# Message Broker
# ============================================
# Options: rabbitmq | kafka (must match backend MESSAGE_BROKER)
MESSAGE_BROKER=rabbitmq

# ============================================
# RabbitMQ (when MESSAGE_BROKER=rabbitmq)
# ============================================
# Or use RABBITMQ_URL for full connection string: amqp://user:password@host:port/vhost
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ============================================
# Kafka (when MESSAGE_BROKER=kafka)
# ============================================
# Comma-separated broker list. Ensure Kafka advertised.listeners matches this.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=arcane-worker
KAFKA_GROUP_ID=arcane-worker
KAFKA_SSL_ENABLED=false
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=plain
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# ============================================
# Worker Settings
# ============================================
WORKER_POLL_INTERVAL_SECONDS=10
WORKER_MAX_CONCURRENT_JOBS=3
WORKER_JOB_LOCK_TTL_SECONDS=300

# Queue/topic names. Must match backend config.
EXPERIMENT_JOBS_TOPIC=experiment-queue
EXPERIMENT_RESULTS_TOPIC=experiment-results-queue
EXPERIMENT_DLQ_QUEUE=experiment-dlq

EVALUATION_JOBS_TOPIC=evaluation-queue
EVALUATION_RESULTS_TOPIC=evaluation-queue-result
EVALUATION_DLQ_QUEUE=evaluation-dlq

# ============================================
# API & Authentication
# ============================================
API_BASE_URL=http://localhost:8085
INTERNAL_API_KEY=your-jwt-or-api-key-token

# ============================================
# LLM Provider Keys
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
